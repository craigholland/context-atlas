# Context Atlas example environment configuration.
# Copy to `.env` for local experimentation when a local environment file is useful.
# As new runtime knobs are introduced, add them here so the supported settings
# surface stays visible and reviewable at the repository root.

# Logging
# Logger name used by the infrastructure logging factory.
CONTEXT_ATLAS_LOGGER_NAME=context_atlas

# Standard Python logging level for the configured logger.
CONTEXT_ATLAS_LOG_LEVEL=INFO

# Enables stable event identifiers on emitted log records.
# Accepted truthy values: 1, true, yes, on
# Accepted falsy values: 0, false, no, off
CONTEXT_ATLAS_LOG_STRUCTURED_EVENTS=true

# Assembly defaults
# Default total budget used by early assembly flows when a caller does not
# override the budget explicitly.
CONTEXT_ATLAS_DEFAULT_TOTAL_BUDGET=2048

# Default number of candidates retained after starter retrieval/ranking.
CONTEXT_ATLAS_DEFAULT_RETRIEVAL_TOP_K=5

# Default compression strategy applied under budget pressure.
# Supported values: truncate, sentence, extractive
CONTEXT_ATLAS_DEFAULT_COMPRESSION_STRATEGY=extractive

# Memory defaults
# Number of newest memory entries that are always retained by the starter policy.
CONTEXT_ATLAS_MEMORY_SHORT_TERM_COUNT=4

# Exponential decay rate applied to long-term memory age in seconds.
CONTEXT_ATLAS_MEMORY_DECAY_RATE=0.001

# Similarity threshold for starter memory deduplication.
# Accepted range: 0.0 to 1.0
CONTEXT_ATLAS_MEMORY_DEDUP_THRESHOLD=0.72

# Future runtime knobs should be added here as they become supported.
# CONTEXT_ATLAS_<SETTING_NAME>=value
