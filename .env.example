# Context Atlas example environment configuration.
# Copy to `.env` for local experimentation when a local environment file is useful.
# As new runtime knobs are introduced, add them here so the supported settings
# surface stays visible and reviewable at the repository root.

# Logging
# Logger name used by the infrastructure logging factory.
CONTEXT_ATLAS_LOGGER_NAME=context_atlas

# Standard Python logging level for the configured logger.
CONTEXT_ATLAS_LOG_LEVEL=INFO

# Enables stable event identifiers on emitted log records.
# Accepted truthy values: 1, true, yes, on
# Accepted falsy values: 0, false, no, off
CONTEXT_ATLAS_LOG_STRUCTURED_EVENTS=true

# Future runtime knobs should be added here as they become supported.
# CONTEXT_ATLAS_<SETTING_NAME>=value
