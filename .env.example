# Context Atlas example environment configuration.
# Copy to `.env` for local experimentation when a local environment file is useful.
# This file is the visible runtime-knob surface for the current MVP golden path:
# install -> configure -> ingest -> assemble -> inspect.
# The same supported knob surface also applies to the current Codex repository
# workflow described in docs/Guides/codex_repository_workflow.md.
# The same supported knob surface also applies to the current technical-builder
# documents-plus-database workflow described in docs/Guides/docs_database_workflow.md.
# The same supported knob surface now also carries the initial low-code workflow
# configuration described in docs/Guides/low_code_workflow.md.
# Context Atlas does not auto-load `.env`; export the values you want into the
# process environment before running starter flows.
# If these variables are unset, `load_settings_from_env()` will fall back to
# validated starter defaults.
# This file intentionally does not expose ranking authority tables, memory
# scoring semantics, or canonical slot identifiers as public runtime knobs.
# As new runtime knobs are introduced, add them here so the supported settings
# surface stays visible and reviewable at the repository root.

# Logging
# Logger name used by the infrastructure logging factory.
CONTEXT_ATLAS_LOGGER_NAME=context_atlas

# Standard Python logging level for the configured logger.
CONTEXT_ATLAS_LOG_LEVEL=INFO

# Enables stable event identifiers on emitted log records.
# Accepted truthy values: 1, true, yes, on
# Accepted falsy values: 0, false, no, off
CONTEXT_ATLAS_LOG_STRUCTURED_EVENTS=true

# Starter flow: assembly defaults
# Default total budget used by early assembly flows when a caller does not
# override the budget explicitly.
CONTEXT_ATLAS_DEFAULT_TOTAL_BUDGET=2048

# Default fraction of the total budget reserved for the starter memory slot
# when the service builds or augments a starter budget profile.
# This is the supported way to change the starter documents-vs-memory split
# without turning canonical slot identifiers into config.
# Accepted range: greater than 0.0 and less than 1.0
CONTEXT_ATLAS_DEFAULT_MEMORY_BUDGET_FRACTION=0.25

# Default number of candidates retained after starter retrieval/ranking.
CONTEXT_ATLAS_DEFAULT_RETRIEVAL_TOP_K=5

# Default compression strategy applied under budget pressure.
# Supported values: truncate, sentence, extractive
CONTEXT_ATLAS_DEFAULT_COMPRESSION_STRATEGY=extractive

# Minimum ranking score required after authority bonus is applied.
CONTEXT_ATLAS_RANKING_MINIMUM_SCORE=0.0

# Approximate characters-per-token heuristic used by starter compression.
CONTEXT_ATLAS_COMPRESSION_CHARS_PER_TOKEN=4

# Minimum candidate-content length required before the starter compression policy
# considers a chunk worth compressing.
CONTEXT_ATLAS_COMPRESSION_MIN_CHUNK_CHARS=20

# Starter flow: memory defaults
# Number of newest memory entries that are always retained by the starter policy.
CONTEXT_ATLAS_MEMORY_SHORT_TERM_COUNT=4

# Exponential decay rate applied to long-term memory age in seconds.
CONTEXT_ATLAS_MEMORY_DECAY_RATE=0.001

# Similarity threshold for starter memory deduplication.
# Accepted range: 0.0 to 1.0
CONTEXT_ATLAS_MEMORY_DEDUP_THRESHOLD=0.72

# Minimum effective long-term memory score required for retention.
CONTEXT_ATLAS_MEMORY_MIN_EFFECTIVE_SCORE=0.1

# Weight applied to query-overlap boosting for long-term memory retention.
CONTEXT_ATLAS_MEMORY_QUERY_BOOST_WEIGHT=0.35

# Low-code workflow defaults
# Selects the low-code preset that will shape the workflow wrapper path.
# Presets should remain outer-layer conveniences over the same shared engine.
# The current supported walkthrough for this path lives in
# docs/Guides/low_code_workflow.md.
CONTEXT_ATLAS_LOW_CODE_PRESET=chatbot_docs_records

# Default docs root for the low-code workflow.
CONTEXT_ATLAS_LOW_CODE_DOCS_ROOT=docs/Guides

# Default record payload file for the low-code workflow.
CONTEXT_ATLAS_LOW_CODE_RECORDS_FILE=examples/docs_database_workflow/sample_records.json

# Enables or disables filesystem-document inputs for the low-code workflow.
CONTEXT_ATLAS_LOW_CODE_INCLUDE_DOCUMENTS=true

# Enables or disables structured-record inputs for the low-code workflow.
CONTEXT_ATLAS_LOW_CODE_INCLUDE_RECORDS=true

# Future runtime knobs should be added here as they become supported.
# CONTEXT_ATLAS_<SETTING_NAME>=value
